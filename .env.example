# ── MySQL database connection ────────────────────────────────
DB_HOST=your.database.host
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
# Optional single-database fallback if databases.json is missing.
DB_NAME=

# Optional path to the database list (default: ./databases.json).
# DATABASES_FILE=./databases.json

# ── Amazon S3 ────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# The S3 bucket name that backups are uploaded to (REQUIRED).
S3_BUCKET=your-bucket-name
# Optional "folder" prefix inside the bucket.
S3_PREFIX=database-backups

# ── Schedule ─────────────────────────────────────────────────
# Every 3 hours. Alternates DatabaseName_1st / DatabaseName_2nd (overwrite).
CRON_SCHEDULE=0 */3 * * *
# Timezone used to evaluate the cron schedule and pick 1st vs 2nd.
TZ=Asia/Singapore

# ── Local files ──────────────────────────────────────────────
BACKUP_DIR=./backups
DELETE_LOCAL_AFTER_UPLOAD=true
GZIP=true

# ── Log API ──────────────────────────────────────────────────
LOG_DIR=./logs
API_PORT=3050
API_HOST=0.0.0.0
