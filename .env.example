# ── MySQL database connection ────────────────────────────────
DB_HOST=your.database.host
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
# Name of the database to back up. Leave empty to dump ALL databases.
DB_NAME=

# ── Amazon S3 ────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# The S3 bucket name that backups are uploaded to (REQUIRED).
S3_BUCKET=your-bucket-name
# Optional "folder" prefix inside the bucket.
S3_PREFIX=database-backups

# ── Schedule ─────────────────────────────────────────────────
# Cron expression. Default = every day at 05:00 AM.
CRON_SCHEDULE=0 5 * * *
# Timezone used to evaluate the cron schedule.
TZ=Asia/Singapore

# ── Local files ──────────────────────────────────────────────
BACKUP_DIR=./backups
DELETE_LOCAL_AFTER_UPLOAD=true
GZIP=true
