{
  "name": "database-uploader",
  "version": "1.0.0",
  "description": "Automatically dumps MySQL databases and uploads rotating 1st/2nd backups to Amazon S3 every 3 hours.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "backup": "node index.js --now",
    "api": "node -e \"require('dotenv').config(); require('./server').startApiServer()\""
  },
  "keywords": [
    "mysql",
    "backup",
    "s3",
    "cron"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.632.0",
    "dotenv": "^16.4.5",
    "mysqldump": "^3.2.0",
    "node-cron": "^3.0.3"
  }
}
